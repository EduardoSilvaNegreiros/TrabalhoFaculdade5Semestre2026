@page
@model LockoutModel
@{
    ViewData["Title"] = "Conta bloqueada";
}

<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
    <div class="card shadow-lg p-5 rounded-4" style="max-width: 480px; width: 95%;">
        <div class="text-center">
            <h1 class="text-danger">@ViewData["Title"]</h1>
            <p class="text-muted">
                Esta conta foi bloqueada. Por favor, tente novamente mais tarde.
            </p>
            <a asp-page="./Login" class="btn btn-primary mt-3 w-50">Voltar para Login</a>
        </div>
    </div>
</div>
