@page
@model LoginWithRecoveryCodeModel

@{
    ViewData["Title"] = "Verificação de código de recuperação";
}

<div class="d-flex justify-content-center align-items-center min-vh-100" style="background: linear-gradient(135deg, #f0f2f5, #d9e2ec);">
    <div class="card shadow-lg p-5 rounded-4" style="width: 420px; max-width: 95%;">
        <div class="text-center mb-4">
            <h2 style="font-weight: 700; color: #343a40;">@ViewData["Title"]</h2>
            <hr />
            <p class="text-muted mb-3">
                Você solicitou login com um código de recuperação. Este login não será lembrado até que você forneça
                um código do aplicativo autenticador ao entrar ou desative a autenticação de dois fatores e entre novamente.
            </p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="form-floating mb-4">
                <input asp-for="Input.RecoveryCode" class="form-control" autocomplete="off" placeholder="Código de recuperação" />
                <label asp-for="Input.RecoveryCode">Código de recuperação</label>
                <span asp-validation-for="Input.RecoveryCode" class="text-danger"></span>
            </div>

            <button type="submit" class="w-100 btn btn-lg btn-primary mb-3" style="font-weight: 500;">
                Entrar
            </button>
        </form>
    </div>

    <!-- Footer fora do card -->
    <footer class="mt-4 text-center text-muted w-100" style="font-size: 0.85rem;">
        &copy; @DateTime.Now.Year - SeuApp
    </footer>
</div>

<style>
    html, body {
        height: 100%;
        margin: 0;
    }

    a:hover, button:hover {
        text-decoration: none;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
