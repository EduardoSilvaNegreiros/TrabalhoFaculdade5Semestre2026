@page
@model GenerateRecoveryCodesModel
@{
    ViewData["Title"] = "Gerar códigos de recuperação do 2FA";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3>@ViewData["Title"]</h3>

<div class="alert alert-warning" role="alert">
    <p>
        <strong>Guarde esses códigos em um local seguro.</strong>
    </p>
    <p>
        Se você perder seu dispositivo e não tiver os códigos de recuperação, perderá o acesso à sua conta.
    </p>
    <p>
        Gerar novos códigos de recuperação não altera as chaves usadas nos aplicativos autenticadores.
        Se você quiser alterar a chave usada no seu aplicativo autenticador, deve <a asp-page="./ResetAuthenticator">redefinir suas chaves do autenticador.</a>
    </p>
</div>

<div class="mt-3">
    <form method="post">
        <button class="w-100 btn btn-danger btn-lg" type="submit">
            Gerar códigos de recuperação
        </button>
    </form>
</div>
