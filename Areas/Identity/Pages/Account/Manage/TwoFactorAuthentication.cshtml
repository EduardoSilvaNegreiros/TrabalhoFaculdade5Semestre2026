@page
@using Microsoft.AspNetCore.Http.Features
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Autenticação em dois fatores (2FA)";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="container min-vh-100 d-flex flex-column justify-content-center align-items-center">
    <div class="card shadow-lg p-4 p-md-5 w-100" style="max-width: 600px; border-radius: 1rem; background: #ffffff;">
        <h3 class="mb-4">@ViewData["Title"]</h3>
        @{
            var consentFeature = HttpContext.Features.Get<ITrackingConsentFeature>();
            if (consentFeature?.CanTrack ?? true)
            {
                if (Model.Is2faEnabled)
                {
                    if (Model.RecoveryCodesLeft == 0)
                    {
                        <div class="alert alert-danger">
                            <strong>Você não tem códigos de recuperação restantes.</strong>
                            <p>Você deve <a asp-page="./GenerateRecoveryCodes">gerar um novo conjunto de códigos de recuperação</a> antes de usar um código de recuperação para login.</p>
                        </div>
                    }
                    else if (Model.RecoveryCodesLeft == 1)
                    {
                        <div class="alert alert-danger">
                            <strong>Você tem 1 código de recuperação restante.</strong>
                            <p>Você pode <a asp-page="./GenerateRecoveryCodes">gerar um novo conjunto de códigos de recuperação</a>.</p>
                        </div>
                    }
                    else if (Model.RecoveryCodesLeft <= 3)
                    {
                        <div class="alert alert-warning">
                            <strong>Você tem @Model.RecoveryCodesLeft códigos de recuperação restantes.</strong>
                            <p>Recomendamos <a asp-page="./GenerateRecoveryCodes">gerar um novo conjunto de códigos de recuperação</a>.</p>
                        </div>
                    }

                    <div class="d-flex flex-column flex-md-row gap-2 mb-3">
                        @if (Model.IsMachineRemembered)
                        {
                            <form method="post" style="display:inline-block">
                                <button type="submit" class="btn btn-outline-primary w-100">Esquecer este navegador</button>
                            </form>
                        }
                        <a asp-page="./Disable2fa" class="btn btn-primary w-100">Desativar 2FA</a>
                        <a asp-page="./GenerateRecoveryCodes" class="btn btn-secondary w-100">Redefinir códigos de recuperação</a>
                    </div>
                }

                <h4 class="mt-4">Aplicativo autenticador</h4>
                <div class="d-flex flex-column flex-md-row gap-2 mb-3">
                    @if (!Model.HasAuthenticator)
                    {
                        <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="btn btn-primary w-100">Adicionar aplicativo autenticador</a>
                    }
                    else
                    {
                        <a id="enable-authenticator" asp-page="./EnableAuthenticator" class="btn btn-primary w-100">Configurar aplicativo autenticador</a>
                        <a id="reset-authenticator" asp-page="./ResetAuthenticator" class="btn btn-secondary w-100">Redefinir aplicativo autenticador</a>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    <strong>Política de privacidade e cookies não aceita.</strong>
                    <p>Você deve aceitar a política antes de ativar a autenticação em dois fatores.</p>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
