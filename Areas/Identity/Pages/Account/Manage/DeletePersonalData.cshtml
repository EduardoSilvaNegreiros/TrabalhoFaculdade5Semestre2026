@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = "Excluir dados pessoais";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="container min-vh-100 d-flex flex-column justify-content-center align-items-center">
    <div class="card shadow-lg p-4 p-md-5 w-100" style="max-width: 600px; border-radius: 1rem; background: #ffffff;">
        <h3 class="mb-4 text-danger">@ViewData["Title"]</h3>

        <div class="alert alert-warning">
            <strong>Excluir seus dados removerá permanentemente sua conta, e isso não poderá ser revertido.</strong>
        </div>

        <form id="delete-user" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            @if (Model.RequirePassword)
            {
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Digite sua senha" />
                    <label asp-for="Input.Password" class="form-label">Senha</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
            }

            <button class="w-100 btn btn-lg btn-danger" type="submit">Excluir dados e encerrar minha conta</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
