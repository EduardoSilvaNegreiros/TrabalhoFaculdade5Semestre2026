@page
@model Disable2faModel
@{
    ViewData["Title"] = "Desativar autenticação em dois fatores (2FA)";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3>@ViewData["Title"]</h3>

<div class="alert alert-warning" role="alert">
    <p>
        <strong>Esta ação apenas desativa a autenticação em dois fatores.</strong>
    </p>
    <p>
        Desativar o 2FA não altera as chaves usadas nos aplicativos autenticadores. Se você quiser alterar a chave usada no seu aplicativo autenticador, você deve <a asp-page="./ResetAuthenticator">redefinir suas chaves do autenticador.</a>
    </p>
</div>

<div class="mt-3">
    <form method="post">
        <button class="w-100 btn btn-danger btn-lg" type="submit">
            Desativar 2FA
        </button>
    </form>
</div>
