@page
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = "Configurar aplicativo autenticador";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />

<h3>@ViewData["Title"]</h3>

<div>
    <p>Para usar um aplicativo autenticador, siga as etapas abaixo:</p>
    <ol class="list">
        <li>
            <p>
                Baixe um aplicativo autenticador de dois fatores, como o
                <strong>Microsoft Authenticator</strong> para
                <a href="https://go.microsoft.com/fwlink/?Linkid=825072" target="_blank">Android</a> ou
                <a href="https://go.microsoft.com/fwlink/?Linkid=825073" target="_blank">iOS</a>,
                ou o <strong>Google Authenticator</strong> para
                <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&amp;hl=pt_BR" target="_blank">Android</a> e
                <a href="https://apps.apple.com/br/app/google-authenticator/id388497605" target="_blank">iOS</a>.
            </p>
        </li>

        <li>
            <p>
                Escaneie o código QR abaixo ou insira esta chave manualmente no aplicativo autenticador:
                <kbd>@Model.SharedKey</kbd>
            </p>

            <div class="alert alert-info">
                Saiba como <a href="https://go.microsoft.com/fwlink/?Linkid=852423" target="_blank">habilitar a geração de QR Code</a>.
            </div>

            <div id="qrCode" class="mb-3"></div>
            <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
        </li>

        <li>
            <p>
                Após escanear o código QR ou inserir a chave acima, seu aplicativo autenticador exibirá
                um código único de seis dígitos. Digite o código no campo abaixo para confirmar.
            </p>

            <div class="row justify-content-center">
                <div class="col-md-6">
                    <form id="send-code" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Code"
                                   class="form-control"
                                   autocomplete="off"
                                   placeholder=" "                
                                   inputmode="numeric"
                                   maxlength="6"
                                   aria-label="Código de verificação" />
                            <label asp-for="Input.Code" class="form-label">Código de verificação</label>
                            <span asp-validation-for="Input.Code" class="text-danger"></span>
                        </div>

                        <button type="submit" class="w-100 btn btn-lg btn-primary">
                            <i class="bi bi-shield-check"></i> Verificar código
                        </button>
                    </form>
                </div>
            </div>
        </li>
    </ol>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        // Validação simples antes do envio
        document.getElementById('send-code')?.addEventListener('submit', function (e) {
            const input = this.querySelector('input[name="Input.Code"]');
            if (!input) return;

            // Limpa espaços e hifens
            input.value = input.value.replace(/\s|-/g, '').trim();

            // Verifica se tem 6 dígitos
            if (!/^\d{6}$/.test(input.value)) {
                e.preventDefault();
                alert('Por favor, insira um código numérico válido de 6 dígitos.');
            }
        });
    </script>
}
