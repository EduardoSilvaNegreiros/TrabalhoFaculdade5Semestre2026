@page
@model ResendEmailConfirmationModel

@{
    ViewData["Title"] = "Reenviar confirmação de e-mail";
}

<div class="container min-vh-100 d-flex flex-column justify-content-center align-items-center">
    <div class="card shadow-lg p-4 p-md-5" style="max-width: 500px; width: 100%; border-radius: 1rem; background: #ffffff;">
        <div class="text-center">
            <h1 class="mb-3" style="font-weight: 700; color: #343a40;">@ViewData["Title"]</h1>
            <h5 class="mb-4 text-muted">Informe seu e-mail para reenviar a confirmação da conta</h5>
            <hr class="mb-4" />

            <form method="post">
                <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" aria-required="true" placeholder="email@exemplo.com" />
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <button type="submit" class="w-100 btn btn-lg btn-primary mb-3" style="font-weight: 500;">
                    Reenviar confirmação
                </button>

                <div class="text-center">
                    <a asp-page="./Login" class="btn btn-link">Voltar para login</a>
                </div>
            </form>
        </div>
    </div>

  
</div>

<style>
    body {
        background: linear-gradient(135deg, #f0f2f5, #d9e2ec);
    }

    a:hover {
        text-decoration: none;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
