@page
@model LogoutModel
@{
    ViewData["Title"] = "Sair";
}

<div class="d-flex justify-content-center align-items-center min-vh-100" style="background: linear-gradient(135deg, #f0f2f5, #d9e2ec);">
    <div class="card shadow-lg p-5 rounded-4 text-center" style="width: 420px; max-width: 95%;">
        <h2 style="font-weight: 700; color: #343a40;">@ViewData["Title"]</h2>
        <hr />

        @{
            if (User.Identity?.IsAuthenticated ?? false)
            {
                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                    <button type="submit" class="btn btn-primary btn-lg mt-3 w-100" style="font-weight: 500;">
                        Clique aqui para sair
                    </button>
                </form>
            }
            else
            {
                <p class="text-muted mt-3">Você saiu da aplicação com sucesso.</p>
                <a asp-page="/Account/Login" class="btn btn-outline-primary mt-3 w-100">Entrar novamente</a>
            }
        }
    </div>

    <!-- Footer fora do card -->
    <footer class="mt-4 text-center text-muted w-100" style="font-size: 0.85rem;">
        &copy; @DateTime.Now.Year - SeuApp
    </footer>
</div>

<style>
    html, body {
        height: 100%;
        margin: 0;
    }

    a:hover, button:hover {
        text-decoration: none;
    }
</style>
