@page
@model ResetPasswordConfirmationModel

@{
    ViewData["Title"] = "Senha redefinida com sucesso";
}

<div class="d-flex justify-content-center align-items-center min-vh-100" style="background: linear-gradient(135deg, #f0f2f5, #d9e2ec);">
    <div class="card shadow-lg p-5 rounded-4" style="width: 420px; max-width: 95%;">
        <div class="text-center">
            <h2 style="font-weight: 700; color: #343a40;">@ViewData["Title"]</h2>
            <p class="mb-4 text-muted">Sua senha foi redefinida com sucesso.</p>
            <a asp-page="./Login" class="btn btn-primary w-100 btn-lg" style="font-weight: 500;">
                Clique aqui para entrar
            </a>
        </div>
    </div>

    <!-- Footer fora do card -->
    <footer class="mt-4 text-center text-muted w-100" style="font-size: 0.85rem;">
        &copy; @DateTime.Now.Year - SeuApp
    </footer>
</div>

<style>
    html, body {
        height: 100%;
        margin: 0;
    }

    a:hover {
        text-decoration: none;
    }
</style>
