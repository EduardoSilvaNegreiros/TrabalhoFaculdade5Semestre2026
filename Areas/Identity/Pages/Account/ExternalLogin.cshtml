@page
@model ExternalLoginModel
@{
    ViewData["Title"] = "Registrar";
}

<div class="d-flex justify-content-center align-items-center vh-100 bg-light">
    <div class="card shadow-lg p-5 rounded-4" style="width: 420px; max-width: 95%;">
        <div class="text-center mb-4">
            <h2>Associar Conta Externa</h2>
            <p class="text-muted">
                Você autenticou com sucesso usando <strong>@Model.ProviderDisplayName</strong>.<br />
                Por favor, insira um endereço de email para este site abaixo e clique em Registrar para finalizar o login.
            </p>
        </div>

        <form asp-page-handler="Confirmation" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="Digite seu email" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-lg mb-3">Registrar</button>
        </form>

        <div class="text-center">
            <a asp-page="./Login" class="fw-bold">Voltar ao login</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
