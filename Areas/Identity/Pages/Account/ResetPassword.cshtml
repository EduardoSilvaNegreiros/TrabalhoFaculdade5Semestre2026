@page
@model ResetPasswordModel

@{
    ViewData["Title"] = "Redefinir senha";
}

<div class="d-flex justify-content-center align-items-center min-vh-100" style="background: linear-gradient(135deg, #f0f2f5, #d9e2ec);">
    <div class="card shadow-lg p-5 rounded-4" style="width: 420px; max-width: 95%;">
        <div class="text-center mb-4">
            <h2 style="font-weight: 700; color: #343a40;">@ViewData["Title"]</h2>
            <p class="text-muted mb-4">Informe seu e-mail e defina uma nova senha</p>
            <hr />
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
            <input asp-for="Input.Code" type="hidden" />

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="seuemail@exemplo.com" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password" type="password" class="form-control" autocomplete="new-password" placeholder="Digite sua nova senha" />
                <label asp-for="Input.Password">Nova senha</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control" autocomplete="new-password" placeholder="Confirme sua nova senha" />
                <label asp-for="Input.ConfirmPassword">Confirme a senha</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="w-100 btn btn-lg btn-primary mb-3" style="font-weight: 500;">
                Redefinir senha
            </button>
        </form>
    </div>

    <!-- Footer fora do card -->
    <footer class="mt-4 text-center text-muted w-100" style="font-size: 0.85rem;">
        &copy; @DateTime.Now.Year - SeuApp
    </footer>
</div>

<style>
    html, body {
        height: 100%;
        margin: 0;
    }

    a:hover {
        text-decoration: none;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
