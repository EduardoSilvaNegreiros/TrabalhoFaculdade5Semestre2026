            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CarrinhoAdicionarRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CarrinhoAdicionarRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CarrinhoResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
