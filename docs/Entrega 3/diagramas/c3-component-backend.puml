@startuml C3_Component_Backend_Beauty_Marketplace
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_WITH_LEGEND()
title Beauty Marketplace - C4 Nível 3 - Component Backend

Container_Boundary(app, "Aplicação ASP.NET Core MVC") {
    Component(produtoController, "ProdutoController", "MVC Controller", "Catálogo público, busca, filtros de beleza, detalhes, avaliações e recomendações de produtos aprovados.")
    Component(carrinhoController, "CarrinhoController", "MVC Controller", "Carrinho do consumidor, itens multi-lojista, checkout MVC, frete e split.")
    Component(pedidosController, "PedidosController", "MVC Controller", "Histórico do consumidor e rastreio por item/lojista.")
    Component(listaController, "ListaDesejosController", "MVC Controller", "Produtos salvos para compra futura.")
    Component(lojistaController, "LojistaController", "MVC Controller", "Dashboard do lojista, vendas, notificações, cadastro/edição de produtos, estoque e status de envio.")
    Component(adminController, "AdminController", "MVC Controller", "Aprovação de lojistas, moderação de produtos, comissões por categoria e mapa de atendimento.")
    Component(apiControllers, "Controllers API", "API JSON", "Endpoints `/api` para catálogo, carrinho, checkout, pedidos e recomendação IA.")
    Component(cartService, "CartService", "Serviço de domínio", "Sincroniza carrinho em sessão e banco, aplica expiração e evita duplicação de itens.")
    Component(checkoutFacade, "CheckoutFacade", "Facade", "Finaliza compra em transação: valida estoque, cria pedido, baixa estoque, calcula frete, split e rastreio.")
    Component(aiService, "AI Recommendation Services", "Factory/Service", "Escolhe OpenAI ou fallback local e retorna recomendações com cards de produto.")
    Component(productImageService, "ProductImageService", "Serviço de domínio", "Valida extensão, tamanho, dimensões e salva imagens enviadas pelo lojista.")
    Component(identity, "ASP.NET Identity", "Framework", "Cadastro, login, roles Consumidor, Lojista e Administrador.")
    Component(dbcontext, "ApplicationDbContext", "EF Core DbContext", "Mapeamento das entidades, chaves, relacionamentos e acesso ao banco.")
    Component(session, "SessionExtensions", "Helper", "Serialização do carrinho na sessão do usuário.")
    Component(seed, "MarketplaceSeeder", "Inicialização", "Cria roles, usuários de demonstração, lojistas, produtos aprovados, categorias e avaliações.")
    Component(integracoes, "Integrações de domínio", "Serviços/regras locais", "Cálculo de frete, prazo, split, repasse, rastreio e notificações demonstráveis.")
}

ContainerDb(sqlite, "SQLite local", "Banco local do protótipo")
ContainerDb(mysql, "MySQL", "Modelo relacional alvo")
ContainerDb(mongo, "MongoDB", "Avaliações ricas")
ContainerDb(redis, "Redis", "Carrinho/cache/ranking")
System_Ext(pgto, "Gateway de pagamento", "Pagamento e split")
System_Ext(frete, "Correios/Transportadoras", "Frete e rastreio")
System_Ext(notif, "E-mail/notificações", "Mensagens")

Rel(produtoController, dbcontext, "Consulta produtos aprovados, lojistas e avaliações")
Rel(carrinhoController, cartService, "Lê, grava e limpa carrinho")
Rel(carrinhoController, checkoutFacade, "Finaliza compra")
Rel(apiControllers, cartService, "Usa carrinho persistente")
Rel(apiControllers, checkoutFacade, "Finaliza checkout via API")
Rel(apiControllers, aiService, "Solicita recomendações IA")
Rel(cartService, session, "Sincroniza sessão")
Rel(cartService, dbcontext, "Persiste carrinho por usuário")
Rel(checkoutFacade, dbcontext, "Cria pedidos e baixa estoque em transação")
Rel(checkoutFacade, integracoes, "Calcula frete, prazo, split e rastreio")
Rel(pedidosController, dbcontext, "Consulta pedidos do consumidor")
Rel(listaController, dbcontext, "Persiste lista de desejos")
Rel(lojistaController, dbcontext, "Consulta vendas e atualiza produtos/status do lojista")
Rel(lojistaController, productImageService, "Valida e salva imagens de produtos")
Rel(adminController, dbcontext, "Atualiza status de lojistas, produtos e comissões")
Rel(identity, dbcontext, "Persiste usuários e roles")
Rel(seed, dbcontext, "Popula dados iniciais")

Rel(dbcontext, sqlite, "Executa protótipo local")
Rel(dbcontext, mysql, "Representa persistência relacional alvo")
Rel(integracoes, pgto, "Integração planejada")
Rel(integracoes, frete, "Integração planejada")
Rel(integracoes, notif, "Integração planejada")
Rel(produtoController, mongo, "Consulta avaliações ricas na arquitetura alvo")
Rel(cartService, redis, "Usa carrinho/cache na arquitetura alvo")

@enduml
