@startuml C2_Container_Beauty_Marketplace
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()
title Beauty Marketplace - C4 Nível 2 - Container

Person(consumidor, "Consumidor")
Person(lojista, "Lojista")
Person(admin, "Administrador")

System_Boundary(sistema, "Beauty Marketplace") {
    Container(web, "Navegador / Mobile Web", "Razor Views, Bootstrap, HTML, CSS e JavaScript", "Interface responsiva para catálogo, carrinho, checkout, pedidos, lojista e administração.")
    Container(app, "Aplicação ASP.NET Core MVC", "ASP.NET Core MVC, EF Core e Identity", "Executa controllers, regras de negócio, autenticação por roles, split, frete, pedidos e administração.")
    ContainerDb(mysql, "MySQL", "Banco relacional", "Modelo SQL oficial da entrega para usuários, lojistas, produtos, pedidos, comissões e avaliações.")
    ContainerDb(sqlite, "SQLite local", "Banco relacional embarcado", "Banco usado apenas para facilitar execução local do protótipo na apresentação.")
    ContainerDb(mongo, "MongoDB", "Banco de documentos", "Armazena avaliações ricas com fotos, vídeos e atributos flexíveis de beleza.")
    ContainerDb(redis, "Redis", "Cache chave-valor", "Mantém carrinho rápido, TTL de carrinho abandonado e ranking de produtos visualizados.")
}

System_Ext(pgto, "Gateway de pagamento", "API externa de pagamento e split")
System_Ext(frete, "Correios/Transportadoras", "API externa de frete, prazo e rastreio")
System_Ext(notif, "E-mail/notificações", "API externa de mensagens transacionais")

Rel(consumidor, web, "Usa pelo navegador ou celular")
Rel(lojista, web, "Gerencia mini-loja e pedidos")
Rel(admin, web, "Administra lojistas e comissões")

Rel(web, app, "Envia requisições HTTP/MVC")
Rel(app, sqlite, "Persiste dados do protótipo local via EF Core")
Rel(app, mysql, "Persiste dados relacionais na arquitetura alvo")
Rel(app, mongo, "Registra prova social flexível")
Rel(app, redis, "Lê e atualiza cache, carrinho e rankings")

Rel(app, pgto, "Solicita pagamento e divisão de valores")
Rel(app, frete, "Consulta frete e rastreio")
Rel(app, notif, "Envia confirmações e alertas")

@enduml
