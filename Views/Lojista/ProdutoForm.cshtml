@model WebApplication1.ViewModels.ProdutoFormViewModel

@{
    var editando = Model.Id.HasValue;
    ViewData["Title"] = editando ? "Editar produto" : "Novo produto";
    var categorias = ViewBag.Categorias as IEnumerable<string> ?? Enumerable.Empty<string>();
    var peles = ViewBag.Peles as IEnumerable<string> ?? Enumerable.Empty<string>();
    var cabelos = ViewBag.Cabelos as IEnumerable<string> ?? Enumerable.Empty<string>();
    var curvaturas = ViewBag.Curvaturas as IEnumerable<string> ?? Enumerable.Empty<string>();
    var tons = ViewBag.Tons as IEnumerable<string> ?? Enumerable.Empty<string>();
    var acabamentos = ViewBag.Acabamentos as IEnumerable<string> ?? Enumerable.Empty<string>();
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
    <div>
        <h1>@ViewData["Title"]</h1>
        <p class="lead">Cadastre produtos com filtros de beleza, estoque e imagem própria da loja.</p>
    </div>
    <a class="btn btn-outline-secondary" asp-controller="Lojista" asp-action="Dashboard" asp-fragment="estoque">Voltar ao painel</a>
</div>

<form asp-controller="Lojista" asp-action="SalvarProduto" method="post" enctype="multipart/form-data" class="product-form">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ImagemUrlAtual" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <section class="form-section">
        <h2>Dados principais</h2>
        <div class="form-grid">
            <div class="filter-wide">
                <label asp-for="Nome" class="form-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Categoria" class="form-label"></label>
                <select asp-for="Categoria" class="form-select">
                    @foreach (var item in categorias)
                    {
                        <option value="@item">@item</option>
                    }
                </select>
                <span asp-validation-for="Categoria" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Marca" class="form-label"></label>
                <input asp-for="Marca" class="form-control" />
                <span asp-validation-for="Marca" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Preco" class="form-label"></label>
                <input asp-for="Preco" class="form-control" type="number" min="0" step="0.01" />
                <span asp-validation-for="Preco" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Estoque" class="form-label"></label>
                <input asp-for="Estoque" class="form-control" type="number" min="0" />
                <span asp-validation-for="Estoque" class="text-danger"></span>
            </div>
            <div class="filter-wide">
                <label asp-for="Descricao" class="form-label"></label>
                <textarea asp-for="Descricao" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Descricao" class="text-danger"></span>
            </div>
            <div class="filter-wide">
                <label asp-for="Composicao" class="form-label"></label>
                <textarea asp-for="Composicao" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Composicao" class="text-danger"></span>
            </div>
        </div>
    </section>

    <section class="form-section">
        <h2>Filtros de beleza</h2>
        <div class="form-grid">
            <div>
                <label asp-for="TipoPele" class="form-label"></label>
                <select asp-for="TipoPele" class="form-select">
                    @foreach (var item in peles)
                    {
                        <option value="@item">@item</option>
                    }
                </select>
            </div>
            <div>
                <label asp-for="TipoCabelo" class="form-label"></label>
                <select asp-for="TipoCabelo" class="form-select">
                    @foreach (var item in cabelos)
                    {
                        <option value="@item">@item</option>
                    }
                </select>
            </div>
            <div>
                <label asp-for="CurvaturaCachos" class="form-label"></label>
                <select asp-for="CurvaturaCachos" class="form-select">
                    @foreach (var item in curvaturas)
                    {
                        <option value="@item">@item</option>
                    }
                </select>
            </div>
            <div>
                <label asp-for="Tom" class="form-label"></label>
                <select asp-for="Tom" class="form-select">
                    @foreach (var item in tons)
                    {
                        <option value="@item">@item</option>
                    }
                </select>
            </div>
            <div>
                <label asp-for="Acabamento" class="form-label"></label>
                <select asp-for="Acabamento" class="form-select">
                    @foreach (var item in acabamentos)
                    {
                        <option value="@item">@item</option>
                    }
                </select>
            </div>
            <label class="form-check filter-check">
                <input asp-for="Vegano" class="form-check-input" />
                <span class="form-check-label">Produto vegano</span>
            </label>
        </div>
    </section>

    <section class="form-section">
        <h2>Imagem</h2>
        <div class="form-grid">
            @if (!string.IsNullOrWhiteSpace(Model.ImagemUrlAtual))
            {
                <div>
                    <label class="form-label">Imagem atual</label>
                    <img class="product-form-preview" src="@Model.ImagemUrlAtual" alt="@Model.Nome" />
                </div>
            }
            <div class="filter-wide">
                <label asp-for="Imagem" class="form-label">Nova imagem</label>
                <input asp-for="Imagem" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                <span asp-validation-for="Imagem" class="text-danger"></span>
                <small class="text-muted d-block mt-1">Use JPG, PNG ou WebP, até 5 MB, com pelo menos 600 px no menor lado.</small>
            </div>
        </div>
    </section>

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-primary" type="submit">Salvar produto</button>
        <a class="btn btn-outline-secondary" asp-controller="Lojista" asp-action="Dashboard" asp-fragment="estoque">Cancelar</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
