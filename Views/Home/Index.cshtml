@{
    ViewData["Title"] = "Beauty Marketplace";
}

<section class="home-hero">
    <div>
        <p class="eyebrow">Beauty Marketplace</p>
        <h1>Produtos de beleza, bem-estar e autocuidado reunidos em uma unica plataforma.</h1>
        <p>Explore opcoes para pele, cabelo e maquiagem, compare categorias e monte sua selecao com mais praticidade.</p>
        <a class="btn btn-primary btn-lg" asp-controller="Produto" asp-action="Index">Comece a comprar</a>
    </div>
</section>

<section class="row g-4 mt-4">
    <div class="col-md-4">
        <div class="feature-block">
            <img src="/images/home/CuidadosComAPele.png.png" alt="Cuidados com a pele" />
            <h2>Escolha por necessidade</h2>
            <p>Filtre produtos por perfil, categoria, marca e preferencias do dia a dia.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-block">
            <img src="/images/home/Maquiagem.jpeg.jpeg" alt="Maquiagem" />
            <h2>Comparacao com contexto</h2>
            <p>Use avaliacoes e informacoes do catalogo para decidir com mais seguranca o que faz sentido para voce.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-block">
            <img src="/images/home/CuidadosComOCabelo.png.png" alt="Cuidados com o cabelo" />
            <h2>Jornada centralizada</h2>
            <p>Reuna itens de diferentes parceiros em uma experiencia unica, simples de acompanhar e finalizar.</p>
        </div>
    </div>
</section>
