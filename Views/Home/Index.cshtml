@{
    ViewData["Title"] = "Beauty Marketplace";
}

<section class="home-hero">
    <div>
        <p class="eyebrow">Beauty Marketplace</p>
        <h1>Beleza, confiança e compra unificada em uma única plataforma.</h1>
        <p>Encontre marcas confiáveis, compare produtos por perfil de beleza e finalize sua rotina em um único carrinho.</p>
        <a class="btn btn-primary btn-lg" asp-controller="Produto" asp-action="Index">Comece a comprar</a>
    </div>
</section>

<section class="row g-4 mt-4">
    <div class="col-md-4">
        <div class="feature-block">
            <img src="/images/home/CuidadosComAPele.png.png" alt="Cuidados com a pele" />
            <h2>Skincare por perfil</h2>
            <p>Filtros por tipo de pele, acabamento, marca e opções veganas.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-block">
            <img src="/images/home/Maquiagem.jpeg.jpeg" alt="Maquiagem" />
            <h2>Prova social</h2>
            <p>Avaliações de clientes ajudam a escolher cores, textura e acabamento.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="feature-block">
            <img src="/images/home/CuidadosComOCabelo.png.png" alt="Cuidados com o cabelo" />
            <h2>Compra sem fragmentação</h2>
            <p>Produtos de diferentes lojistas em uma experiência de compra integrada.</p>
        </div>
    </div>
</section>
