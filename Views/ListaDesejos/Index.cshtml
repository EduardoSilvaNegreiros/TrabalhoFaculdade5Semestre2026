@model List<WebApplication1.Models.ListaDesejosItem>

@{
    ViewData["Title"] = "Lista de desejos";
    var totalFavoritos = Model.Count;
}

<h1>Lista de desejos</h1>

<div class="wishlist-summary mb-4">
    <span>Itens salvos</span>
    <strong>@totalFavoritos</strong>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Sua lista esta vazia. Salve produtos para comprar em uma promocao futura.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var item in Model)
        {
            var produtoIndisponivel = item.Produto == null;

            <div class="col">
                <div class="card product-card h-100 @(produtoIndisponivel ? "wishlist-card-disabled" : string.Empty)">
                    <img src="@item.Produto?.ImagemUrl" class="card-img-top" alt="@item.Produto?.Nome" />
                    <div class="card-body d-flex flex-column">
                        <h2 class="product-title">@(item.Produto?.Nome ?? "Produto indisponivel")</h2>
                        <p class="text-muted">@(item.Produto?.Lojista?.NomeFantasia ?? "Item sem parceiro ativo")</p>
                        @if (produtoIndisponivel)
                        {
                            <p class="wishlist-unavailable-message">Produto indisponivel no momento.</p>
                        }
                        else
                        {
                            <p class="price">@((item.Produto?.Preco ?? 0m).ToString("C"))</p>
                        }
                        <div class="mt-auto d-flex gap-2">
                            @if (!produtoIndisponivel)
                            {
                                <a class="btn btn-primary flex-fill" asp-controller="Produto" asp-action="Detalhes" asp-route-id="@item.ProdutoId">Ver</a>
                            }
                            <form asp-controller="ListaDesejos" asp-action="Alternar" method="post">
                                <input type="hidden" name="produtoId" value="@item.ProdutoId" />
                                <button class="btn btn-outline-danger">Remover</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
