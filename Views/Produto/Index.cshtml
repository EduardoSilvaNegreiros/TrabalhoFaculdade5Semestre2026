@model List<WebApplication1.Models.Produto>

@{
    ViewData["Title"] = "Produtos";
}

<div class="container my-5">
    <h2 class="mb-4" style="font-weight: 700; color:#343a40;">Todos os Produtos</h2>

    <!-- Filtro e pesquisa -->
    <div class="row mb-4 g-2">
        <div class="col-md-6">
            <input id="search" type="text" class="form-control form-control-lg" placeholder="Buscar produto pelo nome..." />
        </div>
        <div class="col-md-6">
            <select id="categoryFilter" class="form-select form-select-lg">
                <option value="">Todas as categorias</option>
                @foreach (var cat in Model.Select(p => p.Categoria).Distinct())
                {
                    <option value="@cat">@cat</option>
                }
            </select>
        </div>
    </div>

    <!-- Produtos -->
    <div class="row row-cols-1 row-cols-md-3 g-4" id="productList">
        @foreach (var produto in Model)
        {
            <div class="col product-card"
                 data-category="@produto.Categoria"
                 data-name="@produto.Nome.ToLower()"
                 data-id="@produto.Id"
                 data-nome="@produto.Nome"
                 data-descricao="@produto.Descricao"
                 data-preco="@produto.Preco.ToString("C")"
                 data-imagem="@produto.ImagemUrl">
                <div class="card h-100 shadow border-0 produto-detalhe" style="cursor:pointer; transition: transform 0.3s, box-shadow 0.3s;">
                    <div class="position-relative">
                        <img src="@(produto.ImagemUrl ?? "/images/produto-placeholder.png")"
                             class="card-img-top"
                             alt="@produto.Nome"
                             style="height: 250px; object-fit: cover; border-radius: 0.5rem 0.5rem 0 0;" />
                        <span class="badge bg-primary position-absolute top-0 end-0 m-2">@produto.Categoria</span>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-truncate" title="@produto.Nome">@produto.Nome</h5>
                        <p class="card-text text-truncate" title="@produto.Descricao">@produto.Descricao</p>
                        <p class="mt-auto mb-3 fw-bold text-primary fs-5">@produto.Preco.ToString("C")</p>
                        <button class="btn btn-success w-100 btn-lg adicionar-carrinho" data-id="@produto.Id">
                            Adicionar ao Carrinho
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Modal Produto -->
<div class="modal fade" id="produtoModal" tabindex="-1" aria-labelledby="produtoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0">
                <h5 class="modal-title" id="produtoModalLabel"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>
            <div class="modal-body d-flex flex-column align-items-center">
                <img id="produtoModalImg" src="" class="img-fluid mb-3 rounded" style="max-height:350px; object-fit:cover;">
                <p id="produtoModalDescricao" class="text-center fs-6"></p>
                <p class="fw-bold text-primary fs-5" id="produtoModalPreco"></p>
                <div class="d-grid w-100">
                    <button id="produtoModalAdicionar" class="btn btn-success btn-lg">Adicionar ao Carrinho</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Notificação do Carrinho -->
<div id="cart-notification" class="toast align-items-center text-white bg-success border-0 position-fixed top-0 end-0 m-3" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="d-flex">
        <div class="toast-body">
            Produto adicionado ao carrinho!
        </div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
</div>

<style>
    #search, #categoryFilter {
        max-width: 100%;
        border-radius: 0.5rem;
    }

    .card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 30px rgba(0,0,0,0.25);
    }

    .card-title {
        font-weight: 600;
        font-size: 1.15rem;
    }

    .card-text {
        font-size: 0.95rem;
        color: #555;
    }

    .btn-success {
        font-weight: 600;
        letter-spacing: 0.5px;
        transition: transform 0.2s;
    }

        .btn-success:hover {
            transform: scale(1.03);
        }
</style>

@section Scripts {
    <script>
        const searchInput = document.getElementById("search");
        const categoryFilter = document.getElementById("categoryFilter");
        const productList = document.getElementById("productList");
        const products = productList.getElementsByClassName("product-card");

        function filterProducts() {
            const searchText = searchInput.value.toLowerCase();
            const selectedCategory = categoryFilter.value.toLowerCase();

            Array.from(products).forEach(prod => {
                const name = prod.dataset.name;
                const category = (prod.dataset.category ?? "").toLowerCase();
                const matchSearch = name.includes(searchText);
                const matchCategory = !selectedCategory || category === selectedCategory;
                prod.style.display = (matchSearch && matchCategory) ? "" : "none";
            });
        }

        searchInput.addEventListener("input", filterProducts);
        categoryFilter.addEventListener("change", filterProducts);

        // Modal
        const modal = new bootstrap.Modal(document.getElementById('produtoModal'));
        const modalTitle = document.getElementById('produtoModalLabel');
        const modalImg = document.getElementById('produtoModalImg');
        const modalDescricao = document.getElementById('produtoModalDescricao');
        const modalPreco = document.getElementById('produtoModalPreco');
        const modalAdicionar = document.getElementById('produtoModalAdicionar');

        Array.from(products).forEach(prod => {
            prod.querySelector('.card').addEventListener('click', function(e){
                if(e.target.classList.contains('adicionar-carrinho')) return;

                modalTitle.textContent = prod.dataset.nome;
                modalDescricao.textContent = prod.dataset.descricao;
                modalPreco.textContent = prod.dataset.preco;
                modalImg.src = prod.dataset.imagem;
                modalAdicionar.dataset.id = prod.dataset.id;

                modal.show();
            });
        });

        modalAdicionar.addEventListener('click', function(){
            const produtoId = this.dataset.id;
            fetch(`/Carrinho/Adicionar/${produtoId}`, {
                method: "POST",
                headers: { "Content-Type": "application/json" }
            })
            .then(response => {
                if(response.status === 401){
                    window.location.href = '/Carrinho/AvisoLogin';
                    return;
                }
                return response.json();
            })
            .then(data => {
                if(data && data.sucesso){
                    const toastEl = document.getElementById('cart-notification');
                    const toast = new bootstrap.Toast(toastEl);
                    toast.show();

                    const countElem = document.getElementById("cart-count");
                    if(countElem) countElem.textContent = data.quantidade;
                    modal.hide();
                }
            });
        });

        document.querySelectorAll(".adicionar-carrinho").forEach(btn => {
            btn.addEventListener("click", function() {
                const produtoId = this.dataset.id;
                fetch(`/Carrinho/Adicionar/${produtoId}`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" }
                })
                .then(response => {
                    if(response.status === 401){
                        window.location.href = '/Carrinho/AvisoLogin';
                        return;
                    }
                    return response.json();
                })
                .then(data => {
                    if(data && data.sucesso){
                        const toastEl = document.getElementById('cart-notification');
                        const toast = new bootstrap.Toast(toastEl);
                        toast.show();

                        const countElem = document.getElementById("cart-count");
                        if (countElem) countElem.textContent = data.quantidade;
                    }
                });
            });
        });
    </script>
}
