@model List<WebApplication1.Models.CarrinhoItem>

@{
    ViewData["Title"] = "Checkout";
    var frete = ViewBag.Frete as decimal? ?? 0m;
    var subtotal = Model.Sum(i => i.Subtotal);
}

<h1>Checkout</h1>

@if (!Model.Any())
{
    <div class="alert alert-info">Não há itens para finalizar.</div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card p-4">
                <h2>Pagamento e entrega</h2>
                <form method="post" asp-controller="Carrinho" asp-action="FinalizarCompra">
                    <label class="form-label mt-3">CEP para entrega</label>
                    <input class="form-control" name="cep" value="@ViewBag.Cep" maxlength="9" />

                    <label class="form-label mt-3">Método de pagamento</label>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="pagamento" id="pix" value="Pix" checked>
                        <label class="form-check-label" for="pix">Pix</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="pagamento" id="cartao" value="Cartão de Crédito">
                        <label class="form-check-label" for="cartao">Cartão de Crédito</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="pagamento" id="boleto" value="Boleto">
                        <label class="form-check-label" for="boleto">Boleto Bancário</label>
                    </div>

                    <button class="btn btn-success btn-lg w-100 mt-4">Confirmar pedido</button>
                </form>
            </div>
        </div>
        <aside class="col-lg-5">
            <div class="summary-box">
                <h2>Distribuição por lojista</h2>
                @foreach (var grupo in Model.GroupBy(i => i.NomeLojista))
                {
                    <div class="split-row">
                        <strong>@grupo.Key</strong>
                        <span>Venda: @((grupo.Sum(i => i.Subtotal)).ToString("C"))</span>
                        <span>Comissão: @((grupo.Sum(i => i.ValorComissao)).ToString("C"))</span>
                        <span>Repasse: @((grupo.Sum(i => i.ValorRepasseLojista)).ToString("C"))</span>
                    </div>
                }
                <hr />
                <p><span>Subtotal</span><strong>@((subtotal).ToString("C"))</strong></p>
                <p><span>Frete</span><strong>@((frete).ToString("C"))</strong></p>
                <p><span>Prazo</span><strong>@ViewBag.Prazo</strong></p>
                <p class="total"><span>Total</span><strong>@((subtotal + frete).ToString("C"))</strong></p>
            </div>
        </aside>
    </div>
}
