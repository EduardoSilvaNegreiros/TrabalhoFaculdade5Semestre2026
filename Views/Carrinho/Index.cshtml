@model List<WebApplication1.Models.CarrinhoItem>

@{
    ViewData["Title"] = "Carrinho";
    var subtotal = Model.Sum(i => i.Subtotal);
    var frete = ViewBag.FreteEstimado as decimal? ?? 0m;
}

<h1>Meu carrinho</h1>

@if (TempData["ErroCarrinho"] is string erroCarrinho)
{
    <div class="alert alert-danger">@erroCarrinho</div>
}

@if (ViewBag.CarrinhoAbandonado == true)
{
    <div class="alert alert-warning">
        Seus itens foram salvos para você continuar a compra quando quiser.
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Seu carrinho está vazio. <a asp-controller="Produto" asp-action="Index">Continue comprando</a>.</div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            @foreach (var grupo in Model.GroupBy(i => new { i.LojistaId, i.NomeLojista }))
            {
                <section class="seller-group mb-4">
                    <h2>@grupo.Key.NomeLojista</h2>
                    @foreach (var item in grupo)
                    {
                        <div class="card cart-item mb-3">
                            <div class="row g-0 align-items-center">
                                <div class="col-md-3">
                                    <img src="@item.ImagemUrl" class="img-fluid rounded-start" alt="@item.Nome" />
                                </div>
                                <div class="col-md-6">
                                    <div class="card-body">
                                        <h3>@item.Nome</h3>
                                        <p class="text-muted mb-1">@item.Categoria</p>
                                        <p class="fw-bold">@((item.Preco).ToString("C")) x @item.Quantidade</p>
                                    </div>
                                </div>
                                <div class="col-md-3 text-md-end p-3">
                                    <form method="post" class="cart-quantity-form mb-2" asp-controller="Carrinho" asp-action="Atualizar" asp-route-id="@item.ProdutoId">
                                        <label class="form-label small mb-1">Quantidade</label>
                                        <div class="input-group input-group-sm">
                                            <input class="form-control" type="number" name="quantidade" value="@item.Quantidade" min="0" />
                                            <button class="btn btn-outline-primary">Atualizar</button>
                                        </div>
                                    </form>
                                    <form method="post" asp-controller="Carrinho" asp-action="Remover" asp-route-id="@item.ProdutoId">
                                        <button class="btn btn-outline-danger btn-sm">Remover</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                    <div class="split-box">
                        <span>Subtotal do lojista: @((grupo.Sum(i => i.Subtotal)).ToString("C"))</span>
                        <span>Comissão da plataforma: @((grupo.Sum(i => i.ValorComissao)).ToString("C"))</span>
                        <span>Repasse ao lojista: @((grupo.Sum(i => i.ValorRepasseLojista)).ToString("C"))</span>
                    </div>
                </section>
            }
        </div>
        <aside class="col-lg-4">
            <div class="summary-box">
                <h2>Pagamento único</h2>
                <p><span>Itens</span><strong>@Model.Sum(i => i.Quantidade)</strong></p>
                <p><span>Subtotal</span><strong>@((subtotal).ToString("C"))</strong></p>
                <p><span>Frete</span><strong>@((frete).ToString("C"))</strong></p>
                <p class="total"><span>Total estimado</span><strong>@((subtotal + frete).ToString("C"))</strong></p>
                <a class="btn btn-success btn-lg w-100" asp-controller="Carrinho" asp-action="EscolherPagamento">Finalizar compra</a>
                <a class="btn btn-outline-secondary w-100 mt-2" asp-controller="Produto" asp-action="Index">Continuar comprando</a>
            </div>
        </aside>
    </div>
}
