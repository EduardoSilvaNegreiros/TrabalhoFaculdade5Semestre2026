@model List<WebApplication1.Models.CarrinhoItem>

@{
    ViewData["Title"] = "Carrinho";
    var subtotal = Model.Sum(i => i.Subtotal);
    var frete = ViewBag.FreteEstimado as decimal? ?? 0m;
    var total = subtotal + frete;
    var quantidadeItens = Model.Sum(i => i.Quantidade);
    var totalLojistas = Model.Select(i => i.LojistaId).Distinct().Count();
}

<section class="cart-hero mb-4">
    <div>
        <p class="eyebrow">Compra unificada</p>
        <h1>Meu carrinho</h1>
        <p>Finalize produtos de diferentes lojistas em um único pagamento, com split e repasse demonstrados por vendedor.</p>
    </div>
    @if (Model.Any())
    {
        <div class="cart-hero-summary">
            <span>@quantidadeItens item(ns)</span>
            <strong>@total.ToString("C")</strong>
            <small>@totalLojistas lojista(s) no carrinho</small>
        </div>
    }
</section>

@if (TempData["ErroCarrinho"] is string erroCarrinho)
{
    <div class="alert alert-danger">@erroCarrinho</div>
}

@if (ViewBag.CarrinhoAbandonado == true)
{
    <div class="alert alert-warning">
        Seus itens foram salvos para você continuar a compra quando quiser.
    </div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <h2>Seu carrinho está vazio</h2>
        <p>Explore o catálogo, escolha produtos de diferentes lojistas e volte aqui para concluir em um pagamento único.</p>
        <a class="btn btn-primary" asp-controller="Produto" asp-action="Index">Ver catálogo</a>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            @foreach (var grupo in Model.GroupBy(i => new { i.LojistaId, i.NomeLojista }))
            {
                var subtotalLojista = grupo.Sum(i => i.Subtotal);
                var comissaoLojista = grupo.Sum(i => i.ValorComissao);
                var repasseLojista = grupo.Sum(i => i.ValorRepasseLojista);

                <section class="seller-group mb-4">
                    <div class="seller-group-header">
                        <div>
                            <span class="eyebrow">Lojista parceiro</span>
                            <h2>@grupo.Key.NomeLojista</h2>
                        </div>
                        <strong>@subtotalLojista.ToString("C")</strong>
                    </div>

                    @foreach (var item in grupo)
                    {
                        <div class="card cart-item mb-3">
                            <div class="row g-0 align-items-center">
                                <div class="col-md-3">
                                    <img src="@item.ImagemUrl" class="img-fluid rounded-start" alt="@item.Nome" />
                                </div>
                                <div class="col-md-6">
                                    <div class="card-body">
                                        <h3>@item.Nome</h3>
                                        <p class="text-muted mb-1">@item.Categoria</p>
                                        <p class="fw-bold mb-0">@item.Preco.ToString("C") x @item.Quantidade</p>
                                    </div>
                                </div>
                                <div class="col-md-3 text-md-end p-3">
                                    <form method="post" class="cart-quantity-form mb-2" asp-controller="Carrinho" asp-action="Atualizar" asp-route-id="@item.ProdutoId">
                                        <label class="form-label small mb-1">Quantidade</label>
                                        <div class="input-group input-group-sm">
                                            <input class="form-control" type="number" name="quantidade" value="@item.Quantidade" min="0" />
                                            <button class="btn btn-outline-primary">Atualizar</button>
                                        </div>
                                    </form>
                                    <form method="post" asp-controller="Carrinho" asp-action="Remover" asp-route-id="@item.ProdutoId">
                                        <button class="btn btn-outline-danger btn-sm">Remover</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="split-box split-box-grid">
                        <div>
                            <span>Subtotal do lojista</span>
                            <strong>@subtotalLojista.ToString("C")</strong>
                        </div>
                        <div>
                            <span>Comissão da plataforma</span>
                            <strong>@comissaoLojista.ToString("C")</strong>
                        </div>
                        <div>
                            <span>Repasse ao lojista</span>
                            <strong>@repasseLojista.ToString("C")</strong>
                        </div>
                    </div>
                </section>
            }
        </div>
        <aside class="col-lg-4">
            <div class="summary-box sticky-summary">
                <span class="eyebrow">Resumo</span>
                <h2>Pagamento único</h2>
                <p><span>Lojistas</span><strong>@totalLojistas</strong></p>
                <p><span>Itens</span><strong>@quantidadeItens</strong></p>
                <p><span>Subtotal</span><strong>@subtotal.ToString("C")</strong></p>
                <p><span>Frete estimado</span><strong>@frete.ToString("C")</strong></p>
                <p class="total"><span>Total estimado</span><strong>@total.ToString("C")</strong></p>
                <a class="btn btn-success btn-lg w-100" asp-controller="Carrinho" asp-action="EscolherPagamento">Finalizar compra</a>
                <a class="btn btn-outline-secondary w-100 mt-2" asp-controller="Produto" asp-action="Index">Continuar comprando</a>
            </div>
        </aside>
    </div>
}
