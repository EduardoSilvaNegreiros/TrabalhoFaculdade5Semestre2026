@{
    ViewData["Title"] = "Compra Concluída";
}

<div class="container my-5 text-center">
    <div class="card shadow-sm border-0 p-5">
        <h2 class="mb-4 fw-bold text-success">Compra Concluída!</h2>
        <p class="mb-4 fs-5">Seu pedido foi realizado com sucesso. Obrigado por comprar conosco!</p>
        <a href="/Produto" class="btn btn-primary btn-lg">Continuar Comprando</a>
        <a href="/Carrinho" class="btn btn-outline-secondary btn-lg ms-2">Ver Carrinho</a>
    </div>
</div>

<style>
    .card {
        border-radius: 0.5rem;
        transition: transform 0.3s, box-shadow 0.3s;
    }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 25px rgba(0,0,0,0.15);
        }

    .btn-primary {
        font-weight: 600;
        letter-spacing: 0.5px;
        transition: transform 0.2s;
    }

        .btn-primary:hover {
            transform: scale(1.03);
        }
</style>
