@model WebApplication1.Models.Pedido?

@{
    ViewData["Title"] = "Compra concluída";
}

<div class="success-panel">
    <h1>Compra concluída</h1>
    <p>Seu pedido foi confirmado. Você pode acompanhar o envio de cada item pelo histórico de pedidos.</p>

    @if (Model != null)
    {
        <p><strong>Pedido #@Model.Id</strong> - @((Model.Total).ToString("C")) - @Model.Status</p>
        <div class="row g-3 mt-3">
            @foreach (var item in Model.Itens)
            {
                <div class="col-md-6">
                    <div class="card p-3 h-100">
                        <strong>@item.NomeProduto</strong>
                        <span>@item.NomeLojista</span>
                        <span>Rastreio: @item.CodigoRastreio</span>
                        <span>Status: @item.StatusEntrega</span>
                    </div>
                </div>
            }
        </div>
    }

    <a class="btn btn-primary mt-4" asp-controller="Pedidos" asp-action="Index">Ver histórico de pedidos</a>
    <a class="btn btn-outline-secondary mt-4" asp-controller="Produto" asp-action="Index">Continuar comprando</a>
</div>
