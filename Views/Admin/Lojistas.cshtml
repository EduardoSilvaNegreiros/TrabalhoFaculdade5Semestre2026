@model List<WebApplication1.Models.Lojista>

@{
    ViewData["Title"] = "Administração";
    var comissoes = ViewBag.Comissoes as List<WebApplication1.Models.ComissaoCategoria> ?? new();
    var produtosPendentes = ViewBag.ProdutosPendentes as List<WebApplication1.Models.Produto> ?? new();
    var pendentes = Model.Count(l => l.Status == "Pendente");
    var aprovados = Model.Count(l => l.Status == "Aprovado");
    var reprovados = Model.Count(l => l.Status == "Reprovado");
}

<section class="admin-hero mb-4">
    <div>
        <p class="eyebrow">Administração</p>
        <h1>Governança do marketplace</h1>
        <p>Aprove lojistas, modere produtos e ajuste comissões por categoria.</p>
    </div>
    <a class="btn btn-primary" asp-controller="Admin" asp-action="MapaAtendimento">Mapa de atendimento</a>
</section>

<div class="dashboard-grid mb-4">
    <div class="metric"><span>Lojistas cadastrados</span><strong>@Model.Count</strong></div>
    <div class="metric metric-alert"><span>Lojistas pendentes</span><strong>@pendentes</strong></div>
    <div class="metric"><span>Aprovados</span><strong>@aprovados</strong></div>
    <div class="metric metric-alert"><span>Produtos pendentes</span><strong>@produtosPendentes.Count</strong></div>
</div>

<section class="mb-4">
    <div class="section-heading">
        <div>
            <p class="eyebrow">Procedência</p>
            <h2>Aprovação de lojistas</h2>
        </div>
        <span class="badge text-bg-light">@pendentes pendente(s)</span>
    </div>
    <p class="text-muted">Controle quais vendedores podem operar na plataforma antes de expor seus produtos ao consumidor.</p>

    <div class="table-responsive data-panel mt-3">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Lojista</th>
                    <th>CNPJ</th>
                    <th>Local</th>
                    <th>Status</th>
                    <th>Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var lojista in Model)
                {
                    var statusClass = lojista.Status switch
                    {
                        "Aprovado" => "text-bg-success",
                        "Reprovado" => "text-bg-danger",
                        _ => "text-bg-warning"
                    };

                    <tr>
                        <td>
                            <strong>@lojista.NomeFantasia</strong>
                            <small class="d-block text-muted">@lojista.Email</small>
                        </td>
                        <td>@lojista.Cnpj</td>
                        <td>@lojista.Cidade/@lojista.Estado</td>
                        <td><span class="badge @statusClass">@lojista.Status</span></td>
                        <td>
                            <form class="d-flex flex-wrap gap-2" asp-controller="Admin" asp-action="AlterarStatus" method="post">
                                <input type="hidden" name="id" value="@lojista.Id" />
                                <button class="btn btn-sm btn-success" name="status" value="Aprovado">Aprovar</button>
                                <button class="btn btn-sm btn-outline-danger" name="status" value="Reprovado">Reprovar</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

<section id="produtos-pendentes" class="mb-4">
    <div class="section-heading">
        <div>
            <p class="eyebrow">Curadoria</p>
            <h2>Produtos aguardando aprovação</h2>
        </div>
        <span class="badge text-bg-light">@produtosPendentes.Count pendente(s)</span>
    </div>
    <p class="text-muted">Produtos criados ou editados pelo lojista ficam pendentes até revisão do administrador.</p>

    @if (!produtosPendentes.Any())
    {
        <div class="alert alert-info">Nenhum produto aguardando moderação.</div>
    }
    else
    {
        <div class="table-responsive data-panel mt-3">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Produto</th>
                        <th>Categoria</th>
                        <th>Lojista</th>
                        <th>Preço</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var produto in produtosPendentes)
                    {
                        <tr>
                            <td>
                                <div class="seller-product-cell">
                                    <img src="@produto.ImagemUrl" alt="@produto.Nome" />
                                    <div>
                                        <strong>@produto.Nome</strong>
                                        <small class="d-block text-muted">@produto.Marca</small>
                                    </div>
                                </div>
                            </td>
                            <td>@produto.Categoria</td>
                            <td>@(produto.Lojista?.NomeFantasia ?? "Lojista parceiro")</td>
                            <td>@produto.Preco.ToString("C")</td>
                            <td>
                                <form class="d-flex flex-wrap gap-2" asp-controller="Admin" asp-action="AlterarStatusProduto" method="post">
                                    <input type="hidden" name="id" value="@produto.Id" />
                                    <button class="btn btn-sm btn-success" name="status" value="@WebApplication1.Models.ProdutoStatusModeracao.Aprovado">Aprovar</button>
                                    <button class="btn btn-sm btn-outline-danger" name="status" value="@WebApplication1.Models.ProdutoStatusModeracao.Reprovado">Reprovar</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section id="comissoes">
    <div class="section-heading">
        <div>
            <p class="eyebrow">Lucratividade</p>
            <h2>Comissões por categoria</h2>
        </div>
        <span class="badge text-bg-light">@comissoes.Count categoria(s)</span>
    </div>
    <p class="text-muted">Defina percentuais diferentes para otimizar a lucratividade da plataforma sem misturar essa função com a experiência de compra.</p>
    <div class="row g-3">
        @foreach (var comissao in comissoes)
        {
            <div class="col-md-4">
                <form class="metric commission-card h-100" asp-controller="Admin" asp-action="AtualizarComissao" method="post">
                    <input type="hidden" name="id" value="@comissao.Id" />
                    <span>@comissao.Categoria</span>
                    <strong>@comissao.Percentual.ToString("0.##")%</strong>
                    <div class="input-group">
                        <input class="form-control" type="number" step="0.1" min="0" max="100" name="percentual" value="@comissao.Percentual.ToString("0.##")" />
                        <span class="input-group-text">%</span>
                    </div>
                    <button class="btn btn-sm btn-outline-primary mt-2">Salvar comissão</button>
                </form>
            </div>
        }
    </div>
</section>
