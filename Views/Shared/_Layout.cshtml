<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BeautyMarket</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication1.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light shadow-sm bg-white">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">BeautyMarket</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarMain">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Início</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Produto" asp-action="Index">Catálogo</a></li>

                        @if (User.IsInRole("Consumidor"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Consumidor" asp-action="Index">Minha área</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Consumidor" asp-action="RecomendacaoIa">Recomendação IA</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Pedidos" asp-action="Index">Pedidos</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="ListaDesejos" asp-action="Index">Lista de Desejos</a></li>
                        }

                        @if (User.IsInRole("Lojista"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Lojista" asp-action="Dashboard">Painel do Lojista</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Lojista" asp-action="Dashboard" asp-fragment="pedidos">Pedidos Recebidos</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Lojista" asp-action="Dashboard" asp-fragment="estoque">Estoque</a></li>
                        }

                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Lojistas">Administração</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Lojistas" asp-fragment="comissoes">Comissões</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="MapaAtendimento">Mapa de Atendimento</a></li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-lg-center">
                        @if (User.IsInRole("Consumidor"))
                        {
                            <li class="nav-item me-3 position-relative">
                                <a class="nav-link cart-link" asp-controller="Carrinho" asp-action="Index">
                                    Carrinho
                                    <span id="cart-count" class="cart-count">0</span>
                                </a>
                            </li>
                        }
                        <partial name="_LoginPartial" />
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="text-center">
        &copy; @DateTime.Now.Year - BeautyMarket
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function atualizarCarrinho() {
            const count = document.getElementById("cart-count");
            if (!count) return;
            fetch("/Carrinho/ObterQuantidade")
                .then(response => response.json())
                .then(data => count.textContent = data.quantidade);
        }

        document.addEventListener("DOMContentLoaded", atualizarCarrinho);
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
